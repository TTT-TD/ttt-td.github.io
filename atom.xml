    <entry>
        <id>https://ttt.td/2023/02/16/adguardhome-server-filter-china-domain.html</id>
        <title>使用AdGuardHome搭建私有DNS并对ChinaDomain进行分流</title>
        <link rel="alternate" href="https://ttt.td/2023/02/16/adguardhome-server-filter-china-domain.html"/>
        <content type="html">&lt;h2 id=&#34;先决条件&#34;&gt;&lt;a href=&#34;#先决条件&#34; class=&#34;headerlink&#34; title=&#34;先决条件&#34;&gt;&lt;/a&gt;先决条件&lt;/h2&gt;&lt;p&gt;编辑&lt;code&gt;AdGuardHome.yaml&lt;/code&gt;设置&lt;code&gt;upstream_dns_file = &amp;quot;/usr/share/adguardhome.upstream&amp;quot;&lt;/code&gt;，设置&lt;code&gt;all_servers = true&lt;/code&gt;，设置&lt;code&gt;cache_optimistic = true&lt;/code&gt;&lt;/p&gt;
&lt;h2 id=&#34;预览&#34;&gt;&lt;a href=&#34;#预览&#34; class=&#34;headerlink&#34; title=&#34;预览&#34;&gt;&lt;/a&gt;预览&lt;/h2&gt;&lt;p&gt;&lt;img src=&#34;https://input-s3.mn.input.im/adm-group/1/20230216/63edd8a26bc44.png&#34;&gt;&lt;/p&gt;
&lt;h2 id=&#34;分流规则&#34;&gt;&lt;a href=&#34;#分流规则&#34; class=&#34;headerlink&#34; title=&#34;分流规则&#34;&gt;&lt;/a&gt;分流规则&lt;/h2&gt;&lt;figure class=&#34;highlight bash&#34;&gt;&lt;table&gt;&lt;tr&gt;&lt;td class=&#34;gutter&#34;&gt;&lt;pre&gt;&lt;span class=&#34;line&#34;&gt;1&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;2&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;3&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;4&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;5&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;6&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;7&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;8&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;9&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;10&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;11&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;12&lt;/span&gt;&lt;br&gt;&lt;/pre&gt;&lt;/td&gt;&lt;td class=&#34;code&#34;&gt;&lt;pre&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;comment&#34;&gt;# 安装脚本&lt;/span&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;curl -o &lt;span class=&#34;string&#34;&gt;&amp;quot;/usr/local/bin/upstream.sh&amp;quot;&lt;/span&gt; &lt;span class=&#34;string&#34;&gt;&amp;quot;https://raw.githubusercontent.com/BigUIFU/AGH_SELF/main/DNS/upsteam.sh&amp;quot;&lt;/span&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;built_in&#34;&gt;chmod&lt;/span&gt; +x /usr/local/bin/upstream.sh&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;/usr/local/bin/upstream.sh&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;comment&#34;&gt;# 创建systemd服务定时更新&lt;/span&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;curl -o &lt;span class=&#34;string&#34;&gt;&amp;quot;/etc/systemd/system/upstream.service&amp;quot;&lt;/span&gt; &lt;span class=&#34;string&#34;&gt;&amp;quot;https://raw.githubusercontent.com/BigUIFU/AGH_SELF/main/DNS/upsteam.service&amp;quot;&lt;/span&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;curl -o &lt;span class=&#34;string&#34;&gt;&amp;quot;/etc/systemd/system/upstream.timer&amp;quot;&lt;/span&gt; &lt;span class=&#34;string&#34;&gt;&amp;quot;https://raw.githubusercontent.com/BigUIFU/AGH_SELF/main/DNS/upsteam.timer&amp;quot;&lt;/span&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;systemctl daemon-reload&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;systemctl &lt;span class=&#34;built_in&#34;&gt;enable&lt;/span&gt; upstream.timer&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;systemctl start upstream.timer&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;systemctl status upstream&lt;/span&gt;&lt;br&gt;&lt;/pre&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/figure&gt;
</content>
